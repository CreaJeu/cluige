<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="cluige" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-fPIC" />
					<Add option="-g" />
					<Add option="-DCLUIGE_DEBUG" />
				</Compiler>
				<Linker>
					<Add library="bin/Debug/pdcurses/pdcurses.dll" />
					<Add directory="bin/Debug/pdcurses" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
			<Target title="DebugLinux">
				<Option output="bin/Debug/cluige" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option additional_output="../PDCurses/x11/libXCurses.so;" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-fPIC" />
					<Add option="-lm" />
					<Add option="-O0" />
					<Add option="-ggdb3" />
					<Add option="-DCLUIGE_DEBUG" />
					<Add option="-DCLUIGE_X11" />
					<Add option="-DXCURSES" />
				</Compiler>
				<Linker>
					<Add option="-Wl,-rpath,&apos;\\$$$$ORIGIN&apos;" />
					<Add library="XCurses" />
					<Add library="m" />
					<Add library="Xaw" />
					<Add library="Xmu" />
					<Add library="Xt" />
					<Add library="X11" />
					<Add library="Xpm" />
					<Add library="SM" />
					<Add library="ICE" />
					<Add library="Xext" />
					<Add library="c" />
					<Add directory="../PDCurses/x11" />
					<Add directory="`cat .cluige_dep_dir`" />
				</Linker>
				<ExtraCommands>
					<Add before='test ! -e .cluige_dep_dir &amp;&amp;  grep -o &quot; -L[^ $]* -l&quot; ../PDCurses/x11/MakefileDebug | sed -n &quot;s/^ -L\\([^ ]*\\) -l.*$/\\1/p; q&quot; &gt; .cluige_dep_dir || echo .cluige_dep_dir ok' />
				</ExtraCommands>
			</Target>
